{
  "compilerOptions": {
    "types": [
      "../../node_modules/vitest/globals",
      "../../node_modules/@types/node",
      "../../node_modules/xterm-headless"
    ],
    "lib": [
      "es5",
      "ES2015",
      "ES2017",
      "ES2020",
      "DOM"
    ],
    "rootDir": ".",
    "paths": {
      "*": [
        "./*"
      ]
    },
    "outDir": "../../out/test",

    "composite": true,
    "downlevelIteration": true,
    "declaration": true,
    "sourceMap": true,
    "removeComments": true,
    "pretty": true,
    "incremental": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true
  },
  "include": [
    "./**/*"
  ],
  "references": [
    { "path": "../tsconfig.json" }
  ]
}
