{
  "compilerOptions": {
    "lib": [
      "es5",
      "ES2015",
      "ES2020"
    ],
    "rootDir": ".",
    "paths": {
      "*": [
        "./*"
      ]
    },
    "outDir": "../out",

    "composite": true,
    "downlevelIteration": true,
    "declaration": true,
    "sourceMap": true,
    "removeComments": true,
    "pretty": true,
    "incremental": true,
    "esModuleInterop": true,
    "strict": true
  },
  "include": [
    "./**/*",
    "../typings/js-shell-engine.d.ts"
  ],
  "exclude": [
    "./test"
  ]
}
